# 本地开发环境变量
# 复制此文件为 .env 并填入实际值：cp .env.example .env

# GitHub OAuth 凭证
# 在 https://github.com/settings/developers 创建 OAuth App
# 回调 URL 设为 http://localhost:4321/api/auth/callback/github
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret

# better-auth 密钥（本地开发可使用默认值）
BETTER_AUTH_SECRET=dev-local-secret-do-not-use-in-production-32chrx

# better-auth 基础 URL
BETTER_AUTH_URL=http://localhost:4321