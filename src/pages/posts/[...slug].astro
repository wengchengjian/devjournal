---
// 文章详情页 /posts/[slug]
export const prerender = true;
import { getCollection, render, type CollectionEntry } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import TableOfContents from "../../components/TableOfContents.astro";
import { formatDateLong, estimateReadingTime } from "../../lib/format";

// 为每篇文章生成静态路径
export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<"blog">;
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const readingTime = estimateReadingTime(post.body ?? '');

// 获取所有文章用于上一篇/下一篇导航
const allPosts = (await getCollection("blog", ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const currentIndex = allPosts.findIndex((p) => p.id === post.id);
const newerPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;
const olderPost =
  currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;

// JSON-LD 结构化数据
const siteUrl = Astro.site?.toString().replace(/\/$/, "") ?? "";
const postUrl = `${siteUrl}/posts/${post.id}/`;
const datePublished = post.data.pubDate.toISOString();
const dateModified = post.data.updatedDate
  ? post.data.updatedDate.toISOString()
  : datePublished;

const jsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "Article",
  headline: post.data.title,
  description: post.data.description,
  datePublished,
  dateModified,
  author: {
    "@type": "Person",
    name: "devjournal",
  },
  publisher: {
    "@type": "Organization",
    name: "devjournal",
    logo: {
      "@type": "ImageObject",
      url: `${siteUrl}/favicon.svg`,
    },
  },
  url: postUrl,
  mainEntityOfPage: {
    "@type": "WebPage",
    "@id": postUrl,
  },
  keywords: post.data.tags,
});
---

<BaseLayout title={`${post.data.title} — devjournal`} description={post.data.description}>
  <script is:inline type="application/ld+json" set:html={jsonLd} />
  <div class="article-layout container">
    <TableOfContents headings={headings} />
    <div class="article-main">
      <!-- 文章头部（Pagefind 索引标题和描述） -->
      <header class="post-header" data-pagefind-meta="title:.post-title" data-pagefind-meta="description:.post-description">
        <h1 class="post-title">{post.data.title}</h1>
        <div class="post-meta">
          {post.data.updatedDate ? (
            <>
              <span class="date-label">发布于</span>
              <time datetime={post.data.pubDate.toISOString()}>
                {formatDateLong(post.data.pubDate)}
              </time>
              <span class="dot">·</span>
              <span class="date-label">更新于</span>
              <time datetime={post.data.updatedDate.toISOString()}>
                {formatDateLong(post.data.updatedDate)}
              </time>
            </>
          ) : (
            <time datetime={post.data.pubDate.toISOString()}>
              {formatDateLong(post.data.pubDate)}
            </time>
          )}
          <span class="dot">·</span>
          <span>{readingTime}</span>
          {
            post.data.tags.length > 0 && (
              <>
                <span class="dot">·</span>
<span class="tags">
                   {post.data.tags.map((tag) => (
                     <a href={`/tags/${tag}/`} class="tag">{tag}</a>
                   ))}
                 </span>
              </>
            )
          }
        </div>
      </header>

      <!-- 正文（Pagefind 索引范围） -->
      <div class="prose" data-pagefind-body>
        <Content />
      </div>

      <!-- 上一篇 / 下一篇 -->
      {
        (newerPost || olderPost) && (
          <nav class="post-nav">
            {olderPost ? (
              <a href={`/posts/${olderPost.id}/`} class="nav-item nav-older">
                <span class="nav-label">← 上一篇</span>
                <span class="nav-title">{olderPost.data.title}</span>
              </a>
            ) : (
              <span />
            )}
            {newerPost ? (
              <a href={`/posts/${newerPost.id}/`} class="nav-item nav-newer">
                <span class="nav-label">下一篇 →</span>
                <span class="nav-title">{newerPost.data.title}</span>
              </a>
            ) : (
              <span />
            )}
          </nav>
        )
      }
    </div>
  </div>
</BaseLayout>

<style>
  /* ============================================================
     双栏网格布局
     ============================================================ */
  .article-layout {
    display: grid;
    grid-template-columns: 1fr 220px;
    gap: var(--space-8);
    align-items: start;
    padding-top: var(--space-8);
    padding-bottom: var(--space-8);
  }

  /* 正文区域：桌面端占第一栏 */
  .article-main {
    min-width: 0;
  }

  /* 桌面端：TOC 粘性侧边栏定位到第二栏 */
  @media (min-width: 1024px) {
    .article-layout :global(.toc-desktop) {
      grid-column: 2;
      grid-row: 1;
    }

    .article-main {
      grid-column: 1;
      grid-row: 1;
    }
  }

  /* 移动端：单栏堆叠（TOC 先行） */
  @media (max-width: 1023px) {
    .article-layout {
      grid-template-columns: 1fr;
    }
  }

  /* ============================================================
     文章头部
     ============================================================ */
  .post-header {
    max-width: var(--content-max);
    margin-inline: auto;
    margin-bottom: var(--space-9);
    padding-bottom: var(--space-7);
    border-bottom: 1px solid var(--color-border);
  }

  .post-title {
    font-family: var(--font-serif);
    font-size: clamp(32px, 5vw, 48px);
    font-weight: 400;
    line-height: var(--leading-snug);
    letter-spacing: var(--tracking-tight);
    margin-bottom: var(--space-4);
    color: var(--color-fg);
  }

  .post-meta {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    display: flex;
    align-items: center;
    gap: var(--space-3);
    flex-wrap: wrap;
  }

  .dot {
    color: var(--color-fg-faint);
  }

  .date-label {
    color: var(--color-fg-faint);
  }

  .tags {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .tag {
    text-transform: uppercase;
    letter-spacing: var(--tracking-wide);
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: color var(--dur-fast) var(--ease);
  }

  .tag:hover {
    color: var(--color-fg);
  }

  /* 居中正文 */
  .prose {
    max-width: var(--content-max);
    margin-inline: auto;
  }

  /* ============================================================
     上一篇/下一篇导航
     ============================================================ */
  .post-nav {
    max-width: var(--content-max);
    margin: var(--space-10) auto 0;
    padding-top: var(--space-7);
    border-top: 1px solid var(--color-border);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-5);
  }

  .nav-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    padding: var(--space-3) 0;
    transition: padding var(--dur) var(--ease);
  }

  .nav-item:hover {
    padding-inline-start: var(--space-3);
  }

  .nav-newer {
    text-align: right;
  }

  .nav-newer:hover {
    padding-inline-start: 0;
    padding-inline-end: var(--space-3);
  }

  .nav-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-fg-muted);
    letter-spacing: var(--tracking-wide);
  }

  .nav-title {
    font-family: var(--font-serif);
    font-size: var(--text-md);
    color: var(--color-fg-secondary);
    line-height: var(--leading-snug);
  }

  /* 小屏：导航堆叠 */
  @media (max-width: 640px) {
    .post-nav {
      grid-template-columns: 1fr;
    }

    .nav-newer {
      text-align: left;
    }
  }
</style>

<!-- 复制按钮交互：纯原生 API，0 框架依赖 -->
<script>
  const buttons = document.querySelectorAll<HTMLButtonElement>(".copy-btn");

  buttons.forEach((btn) => {
    btn.addEventListener("click", async () => {
      const figure = btn.closest(".code-block");
      const pre = figure?.querySelector("pre");
      if (!pre) return;

      const code = pre.innerText;
      try {
        await navigator.clipboard.writeText(code);
        const original = btn.textContent;
        btn.textContent = "已复制 ✓";
        setTimeout(() => {
          btn.textContent = original;
        }, 1500);
      } catch {
        // clipboard API 不可用时的降级
        const original = btn.textContent;
        btn.textContent = "复制失败";
        setTimeout(() => {
          btn.textContent = original;
        }, 1500);
      }
    });
  });
</script>
